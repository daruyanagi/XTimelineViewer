<Window
    x:Class="XTimelineViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="XTimelineViewer">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1"
              Padding="8,4">
            <Button x:Name="PostBtn"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Height="32"
                    Padding="12,0"
                    FontSize="14"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="PostBtn_Click">
                <ToolTipService.ToolTip>新規投稿</ToolTipService.ToolTip>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="✏" VerticalAlignment="Center"/>
                    <TextBlock Text="投稿" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="ThemeToggleBtn"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="32" Height="32"
                    Padding="0"
                    FontSize="16"
                    Click="ThemeToggleBtn_Click">
                <ToolTipService.ToolTip>テーマ切り替え</ToolTipService.ToolTip>
            </Button>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1"
              AllowDrop="True"
              DragOver="MainArea_DragOver"
              Drop="MainArea_Drop">

            <!-- Empty state hint -->
            <Border x:Name="DropHintBorder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="60,40">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <TextBlock Text="🐦"
                               FontSize="52"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="X の URL ショートカットをドロップ"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="タイムラインが横並びで追加されます"
                               FontSize="13"
                               Opacity="0.6"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Timeline scroll area -->
            <ScrollViewer x:Name="TimelineScroll"
                          HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Hidden"
                          Visibility="Collapsed">
                <StackPanel x:Name="TimelinePanel"
                            Orientation="Horizontal"
                            Padding="4"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
